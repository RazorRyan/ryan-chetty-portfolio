---
import { siteConfig } from '@/config/site';
import SectionTitle from './SectionTitle.astro';
---

<section id="contact" class="section-card">
  <SectionTitle title="Contact" subtitle="Open to software engineering leadership and architecture-focused opportunities." />

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="space-y-3 text-sm sm:text-base">
      <a class="link-pill w-full justify-start" href={`mailto:${siteConfig.email}`}>
        <span aria-hidden="true">✉️</span>
        <span>Email: {siteConfig.email}</span>
      </a>
      <a class="link-pill w-full justify-start" href={`tel:${siteConfig.phone}`}>
        <span aria-hidden="true">📞</span>
        <span>Phone: {siteConfig.phone}</span>
      </a>
      {/* Links use href="#" as safe placeholders; real URLs are set by JS below (light obfuscation, not security). */}
      <a id="linkedin-link" class="link-pill w-full justify-start" href="#" target="_blank" rel="noreferrer">
        <span aria-hidden="true">🔗</span>
        <span>LinkedIn</span>
      </a>
      <a id="github-link" class="link-pill w-full justify-start" href="#" target="_blank" rel="noreferrer">
        <span aria-hidden="true">💻</span>
        <span>GitHub</span>
      </a>
    </div>

    <form class="space-y-3 rounded-xl border border-slate-200/80 p-4 dark:border-slate-800" action="#" method="post">
      {/* Replace this static-safe placeholder form with Formspree, Cloudflare Forms, or custom API integration. */}
      <label class="block text-sm font-medium" for="name">Name</label>
      <input id="name" name="name" type="text" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-brand-500 transition focus:ring dark:border-slate-700 dark:bg-slate-900" placeholder="Your name" />

      <label class="block text-sm font-medium" for="email">Email</label>
      <input id="email" name="email" type="email" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-brand-500 transition focus:ring dark:border-slate-700 dark:bg-slate-900" placeholder="you@example.com" />

      <label class="block text-sm font-medium" for="message">Message</label>
      <textarea id="message" name="message" rows="4" class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm outline-none ring-brand-500 transition focus:ring dark:border-slate-700 dark:bg-slate-900" placeholder="Tell me about your project or role"></textarea>

      <button type="submit" class="rounded-full bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-500">Send Message (UI Placeholder)</button>
    </form>
  </div>
</section>

<script>
  // Light obfuscation only — this prevents full URLs from appearing in static HTML.
  // This is NOT a security measure; anyone inspecting the rendered page can still find the URLs.
  const profileLinks: Record<string, string[]> = {
    'github-link': ['https://', 'git', 'hub.com/', 'RazorRyan'],
    'linkedin-link': ['https://', 'www.', 'linkedin.com/in/', 'ryan-chetty-89121865/'],
  };

  Object.entries(profileLinks).forEach(([id, parts]) => {
    const el = document.getElementById(id) as HTMLAnchorElement | null;
    if (el) {
      el.href = parts.join('');
    }
  });
</script>
